---
import "../styles/global.css";
import { LOCALES, DEFAULT_LOCALE, localePath } from "../i18n/utils.js";
import { RELEASES_REPO } from "../lib/release.js";

const {
  lang = DEFAULT_LOCALE,
  title,
  description,
  release,
  canonical: canonicalOverride,
  noAlternates = false,
} = Astro.props;

const site = "https://opn-build.github.io";
const canonical = canonicalOverride ?? `${site}${localePath(lang)}/`;
// hreflang alternates for every locale (good multilingual SEO hygiene)
const alternates = LOCALES.map((l) => ({
  code: l.code,
  href: `${site}${localePath(l.code)}/`,
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="google-site-verification" content="Qz4PRDTfp4xXQNHTuVywoEkDqSkfsy8AGsnYmTSdrVc" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0b0e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f0f4f8" media="(prefers-color-scheme: light)" />

    {
      !noAlternates &&
        alternates.map((a) => (
          <link rel="alternate" hreflang={a.code} href={a.href} />
        ))
    }
    {!noAlternates && <link rel="alternate" hreflang="x-default" href={`${site}/`} />}

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OpenAlive" />
    <meta property="og:locale" content={
      lang === "zh" ? "zh_CN" :
      lang === "pt" ? "pt_BR" :
      lang === "ja" ? "ja_JP" :
      lang === "ko" ? "ko_KR" :
      lang === "fr" ? "fr_FR" :
      lang === "es" ? "es_ES" :
      lang === "ht" ? "ht_HT" : "en_US"
    } />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <!-- Dark (default — all crawlers) -->
    <meta property="og:image" content={`${site}/og-image.png`} />
    <!-- Light (Apple Messages / Safari link preview — respects media) -->
    <meta property="og:image" content={`${site}/og-image-light.png`} media="(prefers-color-scheme: light)" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og-image.png`} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "OpenAlive",
      "operatingSystem": "Windows",
      "applicationCategory": "UtilitiesApplication",
      "applicationSubCategory": "SystemUtility",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "downloadUrl": "https://github.com/opn-build/OpenAlive/releases",
      "softwareVersion": release?.version ?? "",
      "license": "https://www.gnu.org/licenses/gpl-3.0.html",
      "description": description,
      "url": canonical,
      "inLanguage": lang,
      "screenshot": "https://opn-build.github.io/og-image.png",
      "featureList": "Keep session active, No telemetry, No admin rights, Scheduled activation, System tray, 8 languages",
      "author": { "@type": "Organization", "name": "opn-build", "url": "https://github.com/opn-build" },
      "publisher": { "@type": "Organization", "name": "opn-build", "url": "https://github.com/opn-build" }
    })} />

    <!-- Distinctive type: display + body + technical mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Bake the build-time release so the client refresh has a baseline -->
    <meta name="oa:repo" content={RELEASES_REPO} />
    <meta name="oa:version" content={release?.version ?? ""} />
  </head>
  <body>
    <slot />
    <script src="/scripts/refresh.js" defer></script>
  </body>
</html>
