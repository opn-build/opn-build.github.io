---
import LangSwitcher from "./LangSwitcher.astro";
import { RELEASES_REPO } from "../lib/release.js";
const { lang, t, release } = Astro.props;
---

<header class="hdr">
  <div class="container row">
    <a href={lang === "en" ? "/" : `/${lang}/`} class="brand" aria-label="OpenAlive">
      <span class="mark"><span class="pulse"></span></span>
      <span class="word">OpenAlive</span>
    </a>

    <nav class="actions">
      <a
        href={`https://github.com/${RELEASES_REPO}`}
        class="gh"
        rel="noopener"
        target="_blank"
        aria-label={t("nav.github")}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        <span class="gh-label">{t("nav.github")}</span>
      </a>
      <LangSwitcher lang={lang} />
      {release.portableUrl ? (
        <details class="dl-menu">
          <summary class="dl">
            {t("nav.download")}
            <svg class="chev" width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </summary>
          <div class="dl-panel" role="menu">
            <a href={release.downloadUrl} data-oa-download download role="menuitem">
              <strong>{t("nav.installer")}</strong>
              <span>.exe</span>
            </a>
            <a href={release.portableUrl} data-oa-portable download role="menuitem">
              <strong>{t("nav.portable")}</strong>
              <span>.zip</span>
            </a>
          </div>
        </details>
      ) : (
        <a
          href={release.downloadUrl}
          class="dl"
          data-oa-download
          download
        >{t("nav.download")}</a>
      )}
    </nav>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 40;
    padding-block: 0.85rem;
    backdrop-filter: blur(12px);
    background: rgba(10, 11, 14, 0.62);
    border-bottom: 1px solid var(--line-soft);
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.12rem;
    letter-spacing: -0.01em;
  }
  .mark {
    display: inline-grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border: 1px solid var(--signal-deep);
    border-radius: 8px;
    background: var(--signal-faint);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }
  .dl {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.5rem 0.95rem;
    border-radius: 10px;
    border: 1px solid var(--line);
    color: var(--text);
    transition: border-color 0.2s var(--ease), background 0.2s var(--ease);
  }
  .dl:hover {
    border-color: var(--signal);
    background: var(--signal-faint);
    color: var(--signal);
  }
  .dl-menu {
    position: relative;
  }
  summary.dl {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    cursor: pointer;
    user-select: none;
  }
  summary.dl::-webkit-details-marker {
    display: none;
  }
  .chev {
    transition: transform 0.2s var(--ease);
    color: var(--text-faint);
  }
  .dl-menu[open] .chev {
    transform: rotate(180deg);
  }
  .dl-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.5rem);
    min-width: 160px;
    background: var(--bg-elev-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.35rem;
    box-shadow: 0 24px 60px -20px rgba(0, 0, 0, 0.8);
    z-index: 50;
    animation: drop 0.18s var(--ease);
  }
  @keyframes drop {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
  }
  .dl-panel a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.55rem 0.7rem;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-dim);
    transition: background 0.15s var(--ease), color 0.15s var(--ease);
  }
  .dl-panel a:hover {
    background: rgba(255, 255, 255, 0.04);
    color: var(--signal);
  }
  .dl-panel span {
    color: var(--text-faint);
    font-size: 0.75rem;
  }
  .gh {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    padding: 0.5rem 0.75rem;
    border-radius: 10px;
    border: 1px solid var(--line);
    color: var(--text-dim);
    transition: border-color 0.2s var(--ease), color 0.2s var(--ease);
  }
  .gh:hover {
    border-color: var(--signal);
    color: var(--signal);
  }
  @media (max-width: 700px) {
    .gh-label {
      display: none;
    }
  }
  @media (max-width: 540px) {
    .dl {
      display: none;
    }
  }
</style>
