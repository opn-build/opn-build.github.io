---
import { formatSize, RELEASES_HTML } from "../lib/release.js";
const { t, release } = Astro.props;
const size = formatSize(release.sizeBytes);
---

<section class="hero">
  <div class="container grid">
    <div class="copy">
      <p class="eyebrow reveal" style="animation-delay:.05s">
        {t("hero.eyebrow")}
      </p>

      <h1 class="title reveal" style="animation-delay:.12s">
        {t("hero.title")}
      </h1>

      <p class="sub reveal" style="animation-delay:.2s">
        {t("hero.subtitle")}
      </p>

      <div class="cta reveal" style="animation-delay:.28s">
        <a
          class="btn btn-primary"
          data-oa-download
          href={release.downloadUrl}
          rel="noopener"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path
              d="M12 3v12m0 0l-4.5-4.5M12 15l4.5-4.5M5 21h14"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          {t("hero.cta")}
        </a>
        {release.portableUrl ? (
          <a class="btn btn-ghost" href={release.portableUrl} data-oa-portable rel="noopener">
            {t("download.portableButton")}
          </a>
        ) : (
          <a class="btn btn-ghost" href={RELEASES_HTML} rel="noopener" target="_blank">
            {t("download.history")}
          </a>
        )}
      </div>

      <p class="cta-meta reveal" style="animation-delay:.34s">
        <span class="pulse"></span>
        <span data-oa-version>{release.version}</span>
        <span class="sep">·</span>
        <span data-oa-size>{size}</span>
        <span class="sep">·</span>
        <span>Windows</span>
      </p>

      <ul class="chips reveal" style="animation-delay:.42s">
        <li>{t("hero.metaA")}</li>
        <li>{t("hero.metaB")}</li>
        <li>{t("hero.metaC")}</li>
        <li>{t("hero.metaD")}</li>
      </ul>
    </div>

    <!-- Status panel: the "alive" signal made visible -->
    <aside class="panel reveal" style="animation-delay:.3s" aria-hidden="true">
      <div class="panel-bar">
        <span class="tray"><span class="pulse"></span></span>
        <span class="panel-name">OpenAlive</span>
        <span class="panel-min">—</span>
      </div>
      <div class="panel-body">
        <div class="status-line">
          <span class="status-dot"></span>
          <span class="status-txt">SESSION ACTIVE</span>
        </div>

        <svg class="ekg" viewBox="0 0 320 80" preserveAspectRatio="none" role="img">
          <path
            class="ekg-base"
            d="M0 40 H120 l8 -26 l10 52 l8 -40 l7 14 H320"
          ></path>
          <path
            class="ekg-live"
            d="M0 40 H120 l8 -26 l10 52 l8 -40 l7 14 H320"
          ></path>
        </svg>

        <dl class="readout">
          <div><dt>mouse</dt><dd>every 30s</dd></div>
          <div><dt>keyboard</dt><dd>F13</dd></div>
          <div><dt>schedule</dt><dd>09–18 · lunch off</dd></div>
          <div><dt>sleep</dt><dd class="blocked">blocked</dd></div>
        </dl>
      </div>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(3rem, 7vw, 5.5rem);
  }
  .grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.6rem, 6.5vw, 4.6rem);
    line-height: 0.98;
    letter-spacing: -0.035em;
    margin-top: 1.1rem;
    background: linear-gradient(180deg, #fff 30%, #b9c0c9 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .sub {
    margin-top: 1.4rem;
    max-width: 46ch;
    color: var(--text-dim);
    font-size: 1.12rem;
  }
  .cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2rem;
  }
  .cta-meta {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  .cta-meta .sep {
    color: var(--text-faint);
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-top: 1.8rem;
    list-style: none;
  }
  .chips li {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    letter-spacing: 0.03em;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.015);
  }

  /* Status panel */
  .panel {
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background:
      linear-gradient(180deg, var(--bg-elev) 0%, var(--bg-elev-2) 100%);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.03) inset,
      0 40px 90px -40px rgba(0, 0, 0, 0.9);
    overflow: hidden;
  }
  .panel-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--line-soft);
    background: rgba(255, 255, 255, 0.015);
  }
  .tray {
    display: inline-grid;
    place-items: center;
    width: 20px;
    height: 20px;
    border: 1px solid var(--signal-deep);
    border-radius: 6px;
    background: var(--signal-faint);
  }
  .panel-name {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .panel-min {
    margin-left: auto;
    color: var(--text-faint);
  }
  .panel-body {
    padding: 1.4rem 1.3rem 1.5rem;
  }
  .status-line {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--signal);
    box-shadow: 0 0 12px var(--signal);
  }
  .status-txt {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    color: var(--signal);
  }
  .ekg {
    width: 100%;
    height: 80px;
    display: block;
  }
  .ekg path {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .ekg-base {
    stroke: var(--line);
    stroke-width: 1.5;
  }
  .ekg-live {
    stroke: var(--signal);
    stroke-width: 2;
    filter: drop-shadow(0 0 5px var(--signal-glow));
    stroke-dasharray: 70 360;
    animation: trace 2.4s linear infinite;
  }
  @keyframes trace {
    from {
      stroke-dashoffset: 430;
    }
    to {
      stroke-dashoffset: 0;
    }
  }
  .readout {
    margin-top: 1.2rem;
    display: grid;
    gap: 0.55rem;
  }
  .readout > div {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--line-soft);
  }
  .readout dt {
    color: var(--text-faint);
  }
  .readout dd {
    color: var(--text-dim);
  }
  .readout dd.blocked {
    color: var(--signal);
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .panel {
      order: -1;
      max-width: 420px;
    }
  }
</style>
