---
const { t } = Astro.props;

// Icon paths keyed by feature id. Stroke-based, 24x24, currentColor.
const ICONS = {
  mouse: '<rect x="7" y="3" width="10" height="18" rx="5"/><path d="M12 7v3"/>',
  keyboard:
    '<rect x="3" y="6" width="18" height="12" rx="2"/><path d="M7 10h.01M11 10h.01M15 10h.01M8 14h8"/>',
  schedule: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  tray: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 14h5l1.5 2.5h5L16 14h5"/>',
  languages:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.6 2.5 15.4 0 18M12 3c-2.5 2.6-2.5 15.4 0 18"/>',
  autostart: '<path d="M12 3v9"/><path d="M7.5 6.5a8 8 0 1 0 9 0"/>',
  privacy: '<path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9.5 12l1.8 1.8 3.2-3.6"/>',
};

const keys = [
  "mouse",
  "keyboard",
  "schedule",
  "tray",
  "languages",
  "autostart",
  "privacy",
];
---

<section class="features" id="features">
  <div class="container">
    <header class="head">
      <p class="eyebrow">{t("features.eyebrow")}</p>
      <h2 class="section-title">{t("features.title")}</h2>
    </header>

    <ul class="grid">
      {
        keys.map((k, i) => (
          <li class="card" class:list={[{ wide: k === "privacy" }]}>
            <span class="ico">
              <svg
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={ICONS[k]}
              />
            </span>
            <h3>{t(`features.items.${k}.title`)}</h3>
            <p>{t(`features.items.${k}.desc`)}</p>
            <span class="idx">{String(i + 1).padStart(2, "0")}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .features {
    padding-block: clamp(3.5rem, 8vw, 6rem);
    border-top: 1px solid var(--line-soft);
  }
  .head {
    margin-bottom: 2.6rem;
  }
  .head .section-title {
    margin-top: 1rem;
  }
  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .card {
    position: relative;
    padding: 1.6rem 1.5rem 1.7rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: linear-gradient(180deg, var(--bg-elev) 0%, rgba(16, 18, 22, 0.4) 100%);
    overflow: hidden;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      340px 160px at 0% 0%,
      var(--signal-faint),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.3s var(--ease);
  }
  .card:hover {
    border-color: var(--signal-deep);
    transform: translateY(-3px);
  }
  .card:hover::before {
    opacity: 1;
  }
  .card.wide {
    grid-column: span 3;
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    column-gap: 1.2rem;
    align-items: center;
  }
  .card.wide .ico {
    grid-row: span 2;
  }
  .ico {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 11px;
    border: 1px solid var(--line);
    color: var(--signal);
    background: var(--bg);
    margin-bottom: 1.1rem;
    position: relative;
    z-index: 1;
  }
  .card.wide .ico {
    margin-bottom: 0;
    width: 48px;
    height: 48px;
  }
  .card h3 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.18rem;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 1;
  }
  .card p {
    margin-top: 0.5rem;
    color: var(--text-dim);
    font-size: 0.98rem;
    position: relative;
    z-index: 1;
  }
  .idx {
    position: absolute;
    top: 1.2rem;
    right: 1.3rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-faint);
  }

  @media (max-width: 880px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .card.wide {
      grid-column: span 2;
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
    .card.wide {
      grid-column: span 1;
      grid-template-columns: 1fr;
    }
    .card.wide .ico {
      grid-row: auto;
      margin-bottom: 1.1rem;
    }
  }
</style>
