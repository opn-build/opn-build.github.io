---
import VsPage from "../components/VsPage.astro";
---

<VsPage
  slug="caffeine"
  competitor="Caffeine"
  tagline="Adds work schedule, lunch break, and keystroke simulation to a familiar concept"
  metaDescription="OpenAlive vs Caffeine — OpenAlive adds a work schedule, lunch break window, and keystroke simulation to the simple keep-awake concept. Free, open source, 8 languages."
  summary={{
    openalive:
      "A lightweight Windows utility that keeps your session active with configurable mouse movement, optional keystroke simulation, work schedule, and a lunch break window.",
    competitor:
      "A minimal tray utility that prevents your PC from sleeping by pressing F15 periodically. Simple and effective — but does only one thing.",
  }}
  rows={[
    { feature: "Prevents sleep / screen lock", oa: '<span class="check">✓</span>', comp: '<span class="check">✓</span>' },
    { feature: "Method", oa: "Mouse movement + optional keystroke", comp: "Keystroke (F15) only" },
    { feature: "Imperceptible cursor move", oa: '<span class="check">✓</span> Returns to exact position', comp: '<span class="cross">–</span> Keystroke only, no mouse', highlight: true },
    { feature: "Work schedule", oa: '<span class="check">✓</span> Start/end time', comp: '<span class="cross">–</span>', highlight: true },
    { feature: "Lunch break window", oa: '<span class="check">✓</span> Built in', comp: '<span class="cross">–</span>', highlight: true },
    { feature: "Configurable interval", oa: '<span class="check">✓</span>', comp: '<span class="cross">–</span> Fixed' },
    { feature: "Configurable keystroke", oa: '<span class="check">✓</span> Shift, F13, ScrollLock…', comp: "F15 only" },
    { feature: "System tray icon with states", oa: '<span class="check">✓</span> 4 states with color', comp: "Basic on/off icon" },
    { feature: "Languages", oa: '<span class="check">✓</span> 8 languages', comp: "English only" },
    { feature: "Platform", oa: "Windows", comp: "Windows & macOS" },
    { feature: "License", oa: "GPLv3", comp: "Freeware (closed source)" },
    { feature: "Accounts / telemetry", oa: '<span class="check">✓</span> None', comp: "None" },
  ]}
  chooseOpenAlive={[
    "You need your activity to match your actual work hours automatically",
    "You want a lunch break pause without manual toggling",
    "You prefer mouse movement over keystroke-only simulation",
    "You want to know exactly when and why the tool is active",
    "You need it in a language other than English",
  ]}
  chooseCompetitor={[
    "You're on macOS as well as Windows",
    "You want the absolute simplest possible tool with zero configuration",
    "Keystroke-only simulation is enough for your setup",
  ]}
/>
