---
import VsPage from "../components/VsPage.astro";
---

<VsPage
  slug="mouse-jiggler"
  competitor="Mouse Jiggler"
  tagline="Imperceptible movement, work schedule, and active maintenance — without the jiggle"
  metaDescription="OpenAlive vs Mouse Jiggler — OpenAlive moves the cursor imperceptibly (returns to exact position), adds a work schedule and lunch break, and is actively maintained. Free & open source."
  summary={{
    openalive:
      "A modern, actively maintained Windows utility. Moves the cursor by a configurable offset and returns it to the exact position — imperceptibly. Includes work schedule, lunch break, keystroke simulation, and 8 languages.",
    competitor:
      "A simple open source tool that jiggles the mouse cursor at a set interval. Does the job, but the cursor moves visibly and there is no scheduling or active maintenance.",
  }}
  rows={[
    { feature: "Cursor movement", oa: '<span class="check">✓</span> Imperceptible — returns to exact position', comp: "Visible jiggle — cursor stays where it moved", highlight: true },
    { feature: "Keystroke simulation", oa: '<span class="check">✓</span> Shift, F13, ScrollLock…', comp: '<span class="cross">–</span>' },
    { feature: "Work schedule", oa: '<span class="check">✓</span> Start/end time', comp: '<span class="cross">–</span>', highlight: true },
    { feature: "Lunch break window", oa: '<span class="check">✓</span> Built in', comp: '<span class="cross">–</span>' },
    { feature: "Manual toggle", oa: '<span class="check">✓</span>', comp: '<span class="check">✓</span>' },
    { feature: "System tray with states", oa: '<span class="check">✓</span> 4 color states', comp: "Basic tray icon" },
    { feature: "Languages", oa: '<span class="check">✓</span> 8 languages', comp: "English only" },
    { feature: "Active maintenance", oa: '<span class="check">✓</span> Actively maintained', comp: "No recent updates" },
    { feature: "License", oa: "GPLv3", comp: "Open source" },
    { feature: "RAM at idle", oa: "~5–15 MB", comp: "~5 MB" },
    { feature: "Accounts / telemetry", oa: '<span class="check">✓</span> None', comp: "None" },
    { feature: "Start with Windows", oa: '<span class="check">✓</span> No admin required', comp: "Requires manual setup" },
  ]}
  chooseOpenAlive={[
    "You don't want the cursor jumping visibly across your screen",
    "You need the tool to activate and deactivate on a work schedule",
    "You want a lunch break pause built in",
    "You want a tool that is actively maintained and receives updates",
    "You need it in a language other than English",
  ]}
  chooseCompetitor={[
    "You need the absolute minimum: just a jiggle, nothing else",
    "You are already using it and it works for your setup",
  ]}
/>
